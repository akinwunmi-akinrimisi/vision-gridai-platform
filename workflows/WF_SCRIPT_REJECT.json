        "jsonBody": "={{ JSON.stringify({ project_id: $('wf-sr-read-topic').first().json[0]?.project_id || null, topic_id: $('wf-sr-validate').first().json.topic_id, stage: 'script_review', action: 'rejected', details: { feedback: $('wf-sr-validate').first().json.feedback, title: $('wf-sr-read-topic').first().json[0]?.seo_title || null } }) }}",
