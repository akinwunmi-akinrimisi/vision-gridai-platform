    {
      "id": "wf-ta-build-refine-prompt",
      "name": "Build Refine Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1320,
        420
      ],
      "parameters": {
        "jsCode": "const allTopics = $input.first().json;\nconst topics = Array.isArray(allTopics) ? allTopics : [allTopics];\nconst targetId = $('Parse Request').first().json.topic_id;\nconst instructions = $('Parse Request').first().json.instructions;\nconst targetTopic = topics.find(t => t.id === targetId);\nconst otherTopics = topics.filter(t => t.id !== targetId).map(t => ({ topic_number: t.topic_number, seo_title: t.seo_title, playlist_angle: t.playlist_angle, narrative_hook: t.narrative_hook }));\n\nconst prompt = `Refine this YouTube topic based on the user's instructions. IMPORTANT: Consider the other 24 topics below to avoid overlap.\n\nTopic to refine:\n${JSON.stringify(targetTopic, null, 2)}\n\nUser instructions: ${instructions}\n\nOther topics (avoid overlap):\n${JSON.stringify(otherTopics, null, 2)}\n\nReturn ONLY valid JSON with the refined topic fields: { seo_title, narrative_hook, key_segments, estimated_cpm, viral_potential }`;\n\nreturn [{ json: { prompt, targetId, instructions, project_id: $('Parse Request').first().json.project_id, existingHistory: targetTopic?.refinement_history || [] } }];",
        "mode": "runOnceForAllItems"
      }
    },
    {
      "id": "wf-ta-anthropic-refine",
      "name": "Claude: Refine Topic",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1540,
        420
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'claude-sonnet-4-20250514', max_tokens: 4096, messages: [{ role: 'user', content: $json.prompt }] }) }}",
        "options": {
          "timeout": 60000
        }
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "vlfOXwvIUlRYnr41",
          "name": "Anthropic API Key"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
