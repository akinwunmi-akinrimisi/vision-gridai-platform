    {
      "id": "wf-ta-parse-refine",
      "name": "Parse Refine Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2200,
        520
      ],
      "parameters": {
        "jsCode": "const prev = $('Build Refine Prompt').first().json;\nconst response = $input.first().json;\nconst text = (response.content || []).filter(c => c.type === 'text').map(c => c.text).join('');\nlet jsonText = text.replace(/^```(?:json)?\\s*/m, '').replace(/\\s*```$/m, '').trim();\nconst s = jsonText.indexOf('{'), e = jsonText.lastIndexOf('}');\nconst refined = JSON.parse(jsonText.substring(s, e + 1));\nconst history = [...(prev.existingHistory || []), { instruction: prev.instructions, result: refined.seo_title, timestamp: new Date().toISOString() }];\nreturn [{ json: { targetId: prev.targetId, refined, history, project_id: prev.project_id } }];",
        "mode": "runOnceForAllItems"
      }
    },
