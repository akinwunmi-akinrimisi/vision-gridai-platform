        "jsCode": "const response = $input.first().json;\nif (response.error || response.type === 'error') {\n  return [{ json: {\n    isError: true,\n    error_message: response.error?.message || JSON.stringify(response.error || response),\n    topic_id: $('Build Refine Prompt').first().json.targetId,\n    project_id: $('Build Refine Prompt').first().json.project_id\n  }}];\n}\nreturn [{ json: { ...response, isError: false } }];",
        "mode": "runOnceForAllItems"
      }
