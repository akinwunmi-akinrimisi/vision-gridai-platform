    {
      "id": "wf-ta-parse",
      "name": "Parse Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        420,
        300
      ],
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst action = body.action;\nconst topic_ids = body.topic_ids || (body.topic_id ? [body.topic_id] : []);\nconst project_id = body.project_id;\nconst feedback = body.feedback || '';\nconst instructions = body.instructions || '';\nconst fields = body.fields || {};\n\nif (!action) throw new Error('action required');\nif (!topic_ids.length && !['regenerate-rejected'].includes(action)) throw new Error('topic_ids required');\n\nreturn [{ json: { action, topic_ids, project_id, feedback, instructions, fields, topic_id: topic_ids[0] } }];",
        "mode": "runOnceForAllItems"
      }
    },
    {
      "id": "wf-ta-switch",
      "name": "Route by Action",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        640,
        300
      ],
      "parameters": {
        "mode": "expression",
        "numberOutputs": 5,
        "output": "={{ {'approve': 0, 'reject': 1, 'refine': 2, 'edit': 3, 'edit_avatar': 4}[$json.action] }}"
      }
    },
