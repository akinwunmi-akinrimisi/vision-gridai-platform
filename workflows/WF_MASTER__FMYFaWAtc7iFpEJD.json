      ],
      "parameters": {
        "jsCode": "const cfg = $('Set: Global Config').first().json;\nconst rows = $input.first().json.values || [];\nconst pending = rows.findIndex(r => r[8] === 'pending' || r[8] === '');\nif (pending === -1) return [{json:{error:'No pending topics found'}}];\nconst r = rows[pending];\nconst topicId = pending; // 0-based index\nconst topicFolders = JSON.parse(cfg.driveTopicFoldersJson || '{}');\nconst rootFolderId = (topicFolders[topicId+''] || {}).root || cfg.driveRootFolderId;\nconst sd = $getWorkflowStaticData('global');\nsd.context = {\n  topicId,\n  seoTitle: r[3] || '',\n  originalTitle: r[2] || '',\n  angle: r[1] || '',\n  narrativeHook: r[4] || '',\n  keySegments: r[5] || '',\n  estimatedCpm: r[6] || '',\n  viralPotential: r[7] || '',\n  scriptDocId: r[9] || '',\n  scriptDocUrl: r[10] || '',\n  sceneManifestDocId: r[11] || '',\n  audioProgress: r[12] || '',\n  imagesProgress: r[13] || '',\n  i2vProgress: r[14] || '',\n  t2vProgress: r[15] || '',\n  assemblyStatus: r[16] || '',\n  driveVideoUrl: r[17] || '',\n  driveFolderUrl: r[18] || '',\n  youtubeUrl: r[19] || '',\n  config: {\n    sheetId: cfg.sheetId,\n    kieApiKey: cfg.kieApiKey,\n    anthropicApiKey: cfg.anthropicApiKey,\n    driveRootFolderId: cfg.driveRootFolderId,\n    topicRootFolderId: rootFolderId,\n    driveTopicFolders: topicFolders,\n    playlist1Id: cfg.playlist1Id,\n    playlist2Id: cfg.playlist2Id,\n    playlist3Id: cfg.playlist3Id\n  }\n};\nreturn [{json:sd.context}];"
