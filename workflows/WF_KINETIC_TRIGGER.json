        "mode": "runOnceForAllItems",
        "jsCode": "const topic = $('Read Topic').first().json[0];\nconst project = $('Read Project').first().json[0];\n\n// Build the payload for the kinetic service\nconst payload = {\n  topic_id: topic.id,\n  project_id: topic.project_id,\n  seo_title: topic.seo_title || topic.original_title || 'Untitled',\n  script_json: topic.script_json,\n  script_metadata: topic.script_metadata,\n  word_count: topic.word_count,\n  scene_count: topic.scene_count,\n  niche: project.niche,\n  niche_description: project.niche_description || '',\n  style_dna: project.style_dna || '',\n  channel_style: project.channel_style || '2hr_documentary',\n  target_scene_count: project.target_scene_count || 172,\n  callback_url: `${$env.N8N_WEBHOOK_BASE || 'http://localhost:5678/webhook'}/kinetic/complete`\n};\n\nreturn [{ json: payload }];"
      },
