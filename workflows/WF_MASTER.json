    {
      "parameters": {
        "jsCode": "// Handle error: update topic status to failed\nconst topicId = $('Validate').first().json.topic_id;\nconst errorMsg = $input.first().json?.message || 'Pipeline start failed';\n\ntry {\n  await this.helpers.httpRequest({\n    method: 'PATCH',\n    url: `${process.env.SUPABASE_URL}/rest/v1/topics?id=eq.${topicId}`,\n    headers: {\n      'apikey': process.env.SUPABASE_ANON_KEY,\n      'Authorization': `Bearer ${process.env.SUPABASE_SERVICE_ROLE_KEY}`,\n      'Content-Type': 'application/json',\n      'Prefer': 'return=minimal',\n    },\n    body: JSON.stringify({ status: 'failed', error_log: errorMsg, last_status_change: new Date().toISOString() }),\n  });\n\n  // Log the failure\n  await this.helpers.httpRequest({\n    method: 'POST',\n    url: `${process.env.SUPABASE_URL}/rest/v1/production_logs`,\n    headers: {\n      'apikey': process.env.SUPABASE_ANON_KEY,\n      'Authorization': `Bearer ${process.env.SUPABASE_SERVICE_ROLE_KEY}`,\n      'Content-Type': 'application/json',\n      'Prefer': 'return=minimal',\n    },\n    body: JSON.stringify({ topic_id: topicId, stage: 'master', action: 'pipeline_failed', status: 'error', details: { error: errorMsg } }),\n  });\n} catch (e) { /* best effort */ }\n\nreturn [{ json: { topic_id: topicId, error: errorMsg, status: 'failed' } }];"
      },
