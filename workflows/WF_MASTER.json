    {
      "parameters": {
        "jsCode": "// Validate request: extract topic_id and start_from\nconst body = $input.first().json.body || {};\nconst topicId = body.topic_id;\nconst startFrom = body.start_from || 'auto';\n\nif (!topicId) {\n  throw new Error('Missing required field: topic_id');\n}\n\nconst validStages = ['auto', 'script', 'classify', 'images', 'tts', 'assembly', 'thumbnail'];\nif (!validStages.includes(startFrom)) {\n  throw new Error(`Invalid start_from: ${startFrom}. Must be one of: ${validStages.join(', ')}`);\n}\n\nreturn [{ json: { topic_id: topicId, start_from: startFrom } }];"
      },
      "id": "validate",
      "name": "Validate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        640,
        300
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ success: true, data: { topic_id: $json.topic_id, start_from: $json.start_from, message: 'Pipeline started' }, error: null }) }}",
        "options": {
          "responseCode": 202
        }
      },
      "id": "respond-202",
