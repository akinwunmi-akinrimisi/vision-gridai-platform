      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const topic = $('Read Topic + Project').first().json[0];\nconst rules = $('Fetch AU Rules').first().json;\nconst promptResolved = $input.first().json;\n\nconst userInput = {\n  final_script: topic.script_json,\n  final_title: topic.seo_title,\n  final_description: topic.yt_description,\n  topic_niche_variant: topic.niche_variant,\n  au_rules: rules\n};\n\nreturn [{ json: {\n  topic_id: topic.id,\n  prompt_text: promptResolved.prompt_text,\n  user_input: userInput\n} }];"
      }
