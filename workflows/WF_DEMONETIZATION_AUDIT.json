              "name": "system",
              "value": "={{ $json.prompt_text }}"
            },
            {
              "name": "messages",
              "value": "=[{\"role\":\"user\",\"content\":\"Audit this content. Input: {{ JSON.stringify($json.user_input) }}\"}]"
