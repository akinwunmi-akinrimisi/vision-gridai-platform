    },
    {
      "id": "code-parse",
      "name": "Parse Audit Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2080,
        140
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const topic = $('Read Topic + Project').first().json[0];\nconst response = $input.first().json;\nconst payload = response.content?.[0]?.text || '';\n\nlet parsed;\ntry {\n  const jsonText = payload.replace(/^[^{]*/, '').replace(/[^}]*$/, '');\n  parsed = JSON.parse(jsonText);\n} catch (e) {\n  parsed = { overall_decision: 'manual_review_required', error: 'parse_failure', raw: payload.slice(0, 500) };\n}\n\nlet compliance_review_status = 'approved';\nif (parsed.overall_decision === 'manual_review_required') compliance_review_status = 'pending';\nif (parsed.overall_decision === 'block') compliance_review_status = 'rejected';\n\nreturn [{ json: {\n  topic_id: topic.id,\n  audit_result: parsed,\n  compliance_review_status\n} }];"
      }
    },
