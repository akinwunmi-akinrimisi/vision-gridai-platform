        "queryParameters": {
          "parameters": [
            { "name": "select", "value": "id,status,last_status_change,project_id,seo_title,topic_number,supervisor_alerted" },
            { "name": "status", "value": "in.(audio,images,assembling,producing)" }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{$env.SUPABASE_ANON_KEY}}" },
            { "name": "Authorization", "value": "Bearer {{$env.SUPABASE_SERVICE_ROLE_KEY}}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "options": {
          "response": { "response": { "responseFormat": "json" } }
        }
      },
      "id": "fetch-topics",
      "name": "Fetch Active Topics",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 300]
    },
    {
      "parameters": {
        "jsCode": "// Filter topics stuck for more than 2 hours (7200000 ms)\nconst topics = $input.first().json;\nconst now = Date.now();\nconst TWO_HOURS_MS = 7200000;\n\nconst stuckTopics = (Array.isArray(topics) ? topics : []).filter(t => {\n  if (!t.last_status_change) return false;\n  const lastChange = new Date(t.last_status_change).getTime();\n  return (now - lastChange) > TWO_HOURS_MS;\n});\n\nreturn [{ json: { stuckTopics, stuckCount: stuckTopics.length } }];"
      },
      "id": "filter-stuck",
      "name": "Filter Stuck Topics",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 300]
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{$json.stuckCount}}",
              "operation": "larger",
              "value2": 0
            }
          ]
        }
      },
      "id": "has-stuck",
      "name": "Has Stuck Topics?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [880, 300]
    },
    {
      "parameters": {
        "jsCode": "// Split stuck topics into individual items for processing\nconst { stuckTopics } = $input.first().json;\nreturn stuckTopics.map(t => ({ json: t }));"
      },
      "id": "split-stuck",
      "name": "Split Stuck Topics",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1100, 200]
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "batch-loop",
      "name": "Process Each Topic",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [1320, 200]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/scenes",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "topic_id", "value": "eq.{{$json.id}}" },
            { "name": "or", "value": "(audio_status.eq.failed,image_status.eq.failed,video_status.eq.failed)" },
            { "name": "select", "value": "id,scene_number,audio_status,image_status,video_status" }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{$env.SUPABASE_ANON_KEY}}" },
            { "name": "Authorization", "value": "Bearer {{$env.SUPABASE_SERVICE_ROLE_KEY}}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "options": {
          "response": { "response": { "responseFormat": "json" } }
        }
      },
      "id": "check-failed-scenes",
      "name": "Check Failed Scenes",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1540, 200]
    },
    {
      "parameters": {
        "jsCode": "// Determine if this topic has failed scenes\nconst failedScenes = $input.first().json;\nconst topicData = $('Process Each Topic').first().json;\nconst hasFailures = Array.isArray(failedScenes) && failedScenes.length > 0;\n\nreturn [{ json: {\n  ...topicData,\n  hasFailures,\n  failedCount: hasFailures ? failedScenes.length : 0,\n  failedScenes: hasFailures ? failedScenes : []\n}}];"
      },
      "id": "eval-failures",
      "name": "Evaluate Failures",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1760, 200]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.hasFailures}}",
              "value2": true
            }
          ]
