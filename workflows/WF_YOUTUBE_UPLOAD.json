      "id": "check-quota",
      "name": "Check Daily Quota",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [910, 300]
    },
    {
      "parameters": {
        "jsCode": "const topic = $('Load Topic Data').first().json[0] || $('Load Topic Data').first().json;\nconst project = topic.projects || {};\nconst scenes = $('Load Scenes').first().json;\nconst quotaResult = $('Check Daily Quota').first().json;\nlet privacyStatus = $('Parse Input').first().json.privacyStatus;\n\n// Quota check: count uploads today\nconst uploadsToday = Array.isArray(quotaResult) ? quotaResult.length : 0;\nconst quotaExceeded = uploadsToday >= 6;\n\n// If quota exceeded and trying to publish public, override to private\nif (quotaExceeded && privacyStatus === 'public') {\n  privacyStatus = 'private';\n}\n\n// Build chapter timestamps from scenes\nconst chapterMap = new Map();\nconst sceneList = Array.isArray(scenes) ? scenes : [];\nfor (const scene of sceneList) {\n  if (scene.chapter && !chapterMap.has(scene.chapter)) {\n    const ms = scene.start_time_ms || 0;\n    const totalSec = Math.floor(ms / 1000);\n    const h = Math.floor(totalSec / 3600);\n    const m = Math.floor((totalSec % 3600) / 60);\n    const s = totalSec % 60;\n    const ts = `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;\n    chapterMap.set(scene.chapter, ts);\n  }\n}\n\nconst chapters = Array.from(chapterMap.entries())\n  .map(([name, ts]) => `${ts} ${name}`)\n  .join('\\n');\n\n// Build description\nconst meta = topic.script_metadata || {};\nconst hook = topic.narrative_hook || '';\nconst tags = meta.tags || [];\nconst hashtags = tags.slice(0, 5).map(t => '#' + t.replace(/\\s+/g, '')).join(' ');\n\nconst description = [\n  hook,\n  '',\n  'Chapters:',\n  chapters || '00:00:00 Introduction',\n  '',\n  hashtags,\n  '',\n  '---',\n  'Produced with Vision GridAI Platform'\n].join('\\n');\n\n// Determine playlist ID\nconst playlistGroup = topic.playlist_group || 1;\nconst playlistId = playlistGroup === 1 ? project.youtube_playlist1_id\n  : playlistGroup === 2 ? project.youtube_playlist2_id\n  : project.youtube_playlist3_id;\n\nconst title = topic.seo_title || topic.original_title || 'Untitled Video';\n\nreturn [{ json: {\n  topicId: topic.id,\n  projectId: project.id,\n  title: title.substring(0, 100),\n  description: description.substring(0, 5000),\n  tags: tags.slice(0, 30),\n  categoryId: '27',\n  privacyStatus,\n  scheduledPublishAt: topic.scheduled_publish_at || null,\n  driveVideoUrl: topic.drive_video_url,\n  driveFileId: topic.drive_video_url ? topic.drive_video_url.match(/\\/d\\/([^\\/]+)/)?.[1] || '' : '',\n  thumbnailUrl: topic.thumbnail_url,\n  playlistId: playlistId || null,\n  quotaExceeded,\n  scenes: sceneList\n} }];"
      },
