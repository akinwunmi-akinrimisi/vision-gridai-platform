      "id": "update-progress-metadata",
      "name": "Update Progress - Metadata",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2890, 300]
    },
    {
      "parameters": {
        "jsCode": "const scenes = $('Prepare YouTube Metadata').first().json.scenes || [];\n\n// Build SRT content from scenes\nlet srt = '';\nlet counter = 1;\nfor (const scene of scenes) {\n  const startMs = scene.start_time_ms || 0;\n  const endMs = scene.end_time_ms || (startMs + (scene.audio_duration_ms || 3000));\n  const text = scene.narration_text || '';\n  if (!text) continue;\n\n  const formatTime = (ms) => {\n    const totalSec = Math.floor(ms / 1000);\n    const h = Math.floor(totalSec / 3600);\n    const m = Math.floor((totalSec % 3600) / 60);\n    const s = totalSec % 60;\n    const milli = ms % 1000;\n    return `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')},${String(milli).padStart(3,'0')}`;\n  };\n\n  srt += `${counter}\\n${formatTime(startMs)} --> ${formatTime(endMs)}\\n${text}\\n\\n`;\n  counter++;\n}\n\nreturn [{ json: { srtContent: srt } }];"
      },
