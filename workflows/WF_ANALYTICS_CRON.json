    {
      "parameters": {
        "jsCode": "// Build YouTube Analytics API request parameters\nconst { videoIdString, allTopics } = $('Process Topics & Transitions').first().json;\n\nconst now = new Date();\nconst ninetyDaysAgo = new Date(now.getTime() - 90 * 24 * 60 * 60 * 1000);\n\nconst startDate = ninetyDaysAgo.toISOString().split('T')[0];\nconst endDate = now.toISOString().split('T')[0];\n\nreturn [{\n  json: {\n    startDate,\n    endDate,\n    videoIdString,\n    allTopics,\n    analyticsUrl: `https://youtubeanalytics.googleapis.com/v2/reports?ids=channel==MINE&startDate=${startDate}&endDate=${endDate}&metrics=views,estimatedMinutesWatched,averageViewDuration,averageViewPercentage,likes,comments,subscribersGained,estimatedRevenue,cpm,impressions&dimensions=video&filters=video==${videoIdString}&sort=-views`\n  }\n}];"
      },
      "id": "build-analytics-query",
      "name": "Build Analytics Query",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1360, 540]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{$json.analyticsUrl}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "authentication": "oAuth2",
        "options": {
          "response": { "response": { "responseFormat": "json" } }
        }
      },
      "id": "youtube-analytics-api",
      "name": "YouTube Analytics API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1580, 540],
      "credentials": {
        "oAuth2Api": { "id": "youtube-oauth2", "name": "YouTube OAuth2" }
      },
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Parse YouTube Analytics response and map to topic updates\nconst response = $input.first().json;\nconst allTopics = $('Build Analytics Query').first().json.allTopics;\n\n// Handle API errors (403 scope issue, empty results, etc.)\nif (response.error) {\n  const errorCode = response.error.code || 'unknown';\n  const errorMsg = response.error.message || JSON.stringify(response.error);\n  return [{\n    json: {\n      updates: [],\n      videosUpdated: 0,\n      error: true,\n      errorCode,\n      errorMessage: errorMsg,\n      scopeWarning: errorCode === 403 ? 'YouTube OAuth2 credential requires yt-analytics.readonly scope' : null\n    }\n  }];\n}\n\nconst rows = response.rows || [];\nif (rows.length === 0) {\n  return [{ json: { updates: [], videosUpdated: 0, error: false } }];\n}\n\n// Column order: videoId, views, estimatedMinutesWatched, averageViewDuration,\n// averageViewPercentage, likes, comments, subscribersGained, estimatedRevenue, cpm, impressions\nconst updates = rows.map(row => {\n  const [videoId, views, watchMinutes, avgDuration, avgPct, likes, comments, subsGained, revenue, cpm, impressions] = row;\n\n  // Find matching topic\n  const topic = allTopics.find(t => t.youtube_video_id === videoId);\n  if (!topic) return null;\n\n  // Format avgDuration (seconds) as M:SS\n  const durationMin = Math.floor(avgDuration / 60);\n  const durationSec = Math.round(avgDuration % 60);\n  const avgViewDuration = `${durationMin}:${String(durationSec).padStart(2, '0')}`;\n\n  // Compute CTR: views / impressions * 100\n  const ctr = impressions > 0 ? Math.round((views / impressions) * 10000) / 100 : 0;\n\n  return {\n    topicId: topic.id,\n    youtubeVideoId: videoId,\n    yt_views: views,\n    yt_watch_hours: Math.round((watchMinutes / 60) * 100) / 100,\n    yt_avg_view_duration: avgViewDuration,\n    yt_avg_view_pct: Math.round(avgPct * 100) / 100,\n    yt_ctr: ctr,\n    yt_impressions: impressions,\n    yt_likes: likes,\n    yt_comments: comments,\n    yt_subscribers_gained: subsGained,\n    yt_estimated_revenue: Math.round(revenue * 100) / 100,\n    yt_actual_cpm: Math.round(cpm * 100) / 100\n  };\n}).filter(Boolean);\n\nreturn [{ json: { updates, videosUpdated: updates.length, error: false } }];"
      },
      "id": "parse-analytics",
      "name": "Parse Analytics Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1800, 540]
    },
