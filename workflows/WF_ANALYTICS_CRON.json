        "jsonBody": "={\n  \"stage\": \"analytics\",\n  \"action\": \"completed\",\n  \"details\": {\n    \"videos_updated\": {{$('Parse Analytics Response').first().json.videosUpdated || 0}},\n    \"transitions\": {{$('Process Topics & Transitions').first().json.transitionCount || 0}},\n    \"source\": \"{{$('Normalize Input').first().json.source}}\",\n    \"timestamp\": \"{{ new Date().toISOString() }}\"\n  }\n}"
      },
      "id": "log-completion",
      "name": "Log Completion",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2680, 420]
    },
    {
      "parameters": {
        "jsCode": "// Build response for webhook trigger\nconst videosUpdated = $('Parse Analytics Response').first()?.json?.videosUpdated || 0;\nconst transitionCount = $('Process Topics & Transitions').first()?.json?.transitionCount || 0;\nconst error = $('Parse Analytics Response').first()?.json?.error || false;\nconst scopeWarning = $('Parse Analytics Response').first()?.json?.scopeWarning || null;\n\nreturn [{\n  json: {\n    success: !error,\n    videos_updated: videosUpdated,\n    transitions: transitionCount,\n    ...(scopeWarning ? { warning: scopeWarning } : {}),\n    ...(error ? { error: $('Parse Analytics Response').first()?.json?.errorMessage } : {})\n  }\n}];"
      },
      "id": "build-response",
      "name": "Build Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2900, 420]
    },
