    {
      "parameters": {
        "jsCode": "// Handle private-to-public transitions for scheduled and over-quota videos\nconst topics = $input.first().json;\nconst allTopics = Array.isArray(topics) ? topics : [];\nconst now = new Date();\n\n// Find scheduled videos whose publish time has passed\nconst transitionCandidates = allTopics.filter(t => {\n  if (t.status === 'scheduled' && t.published_at) {\n    return new Date(t.published_at) <= now;\n  }\n  // Also catch videos stuck in 'publishing' (over-quota private uploads)\n  if (t.status === 'publishing') {\n    return true;\n  }\n  return false;\n});\n\n// Collect video IDs for analytics pull (all topics with youtube_video_id)\nconst videoIds = allTopics\n  .filter(t => t.youtube_video_id)\n  .map(t => t.youtube_video_id);\n\nreturn [{\n  json: {\n    allTopics,\n    transitionCandidates,\n    transitionCount: transitionCandidates.length,\n    videoIds,\n    videoIdString: videoIds.join(','),\n    totalVideos: videoIds.length\n  }\n}];"
      },
      "id": "process-topics",
      "name": "Process Topics & Transitions",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [920, 420]
