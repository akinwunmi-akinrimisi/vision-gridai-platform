      {
        "parameters": {
          "jsCode": "// Determine the next pipeline stage based on topic status fields\nconst topic = $input.first().json[0];\nif (!topic) throw new Error('Topic not found');\n\nconst startFrom = $('Validate').first().json.start_from;\nconst topicId = topic.id;\nconst projectId = topic.order_id;\n\nlet nextStage = startFrom;\n\nif (startFrom === 'auto') {\n  // Determine next stage based on topic's current state\n  if (!topic.script_json || topic.status === 'pending' || topic.status === 'approved') {\n    nextStage = 'script';\n  } else if (topic.script_json && topic.scene_count > 0 && topic.status === 'script_approved') {\n    // Script exists and is approved, check if scenes have been classified\n    nextStage = 'classify';\n  } else if (topic.images_progress === 'pending' || topic.images_progress === null) {\n    nextStage = 'images';\n  } else if (topic.audio_progress === 'pending' || topic.audio_progress === null) {\n    nextStage = 'tts';\n  } else if (topic.assembly_status === 'pending' || topic.assembly_status === null) {\n    nextStage = 'assembly';\n  } else if (!topic.thumbnail_url) {\n    nextStage = 'thumbnail';\n  } else {\n    nextStage = 'complete';\n  }\n}\n\nreturn [{ json: { next_stage: nextStage, video_id: topicId, order_id: projectId, topic_status: topic.status } }];"
        },
